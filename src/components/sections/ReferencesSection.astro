---
import Container from "@/components/layout/Container.astro";
import SectionLabel from "@/components/shared/SectionLabel.astro";
import ScrollReveal from "@/components/shared/ScrollReveal.astro";
import { Image } from "astro:assets";
import flaschnereiHero from "@/assets/flaschnerei-just-hero.webp";
import flaschnereiLeistungen from "@/assets/flaschnerei-just-leistungen.webp";
import dachdoktorHero from "@/assets/dachdoktor-hero.webp";
import dachdoktorLeistungen from "@/assets/dachdoktor-leistungen.webp";
---
<section id="referenzen" class="bg-dark py-[clamp(80px,10vw,160px)]">
  <Container>
    <ScrollReveal>
      <SectionLabel text="Umgesetzte Projekte" dark />
      <h2 class="mb-6 font-heading text-3xl text-white sm:text-4xl">Referenzen</h2>
      <p class="mb-16 max-w-lg text-dark-muted">
        Ein Blick in bereits umgesetzte Webseiten. Weitere Projekte folgen.
      </p>
    </ScrollReveal>

    <div class="space-y-20">
      <!-- Flaschnerei Just -->
      <ScrollReveal>
        <div class="group">
          <div class="grid gap-4 md:grid-cols-2">
            <a
              href="https://www.flaschnerei-just.de"
              target="_blank"
              rel="noopener noreferrer"
              class="relative overflow-hidden rounded-xl"
            >
              <Image
                src={flaschnereiHero}
                alt="Flaschnerei Olaf Just – Startseite"
                class="h-full w-full object-cover object-top transition-transform duration-500 group-hover:scale-[1.02]"
                widths={[600, 900]}
                sizes="(max-width: 768px) 100vw, 50vw"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 transition-opacity group-hover:opacity-100"></div>
            </a>
            <a
              href="https://www.flaschnerei-just.de"
              target="_blank"
              rel="noopener noreferrer"
              class="relative hidden overflow-hidden rounded-xl md:block"
            >
              <Image
                src={flaschnereiLeistungen}
                alt="Flaschnerei Olaf Just – Leistungen"
                class="h-full w-full object-cover object-top transition-transform duration-500 group-hover:scale-[1.02]"
                widths={[600, 900]}
                sizes="50vw"
              />
            </a>
          </div>
          <div class="mt-5 flex items-center justify-between">
            <div>
              <h3 class="font-heading text-xl text-white">Flaschnerei Olaf Just</h3>
              <p class="text-sm text-dark-muted">www.flaschnerei-just.de</p>
            </div>
            <a
              href="https://www.flaschnerei-just.de"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sm font-medium text-emerald-400 transition-colors hover:text-emerald-300"
            >
              Website ansehen
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>
      </ScrollReveal>

      <!-- Dachdoktor -->
      <ScrollReveal>
        <div class="group">
          <div class="grid gap-4 md:grid-cols-2">
            <a
              href="https://new.dachdoktor-meisterbetrieb.de/"
              target="_blank"
              rel="noopener noreferrer"
              class="relative overflow-hidden rounded-xl"
            >
              <Image
                src={dachdoktorHero}
                alt="Der Dachdoktor – Robert Storey – Startseite"
                class="h-full w-full object-cover object-top transition-transform duration-500 group-hover:scale-[1.02]"
                widths={[600, 900]}
                sizes="(max-width: 768px) 100vw, 50vw"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 transition-opacity group-hover:opacity-100"></div>
            </a>
            <a
              href="https://new.dachdoktor-meisterbetrieb.de/"
              target="_blank"
              rel="noopener noreferrer"
              class="relative hidden overflow-hidden rounded-xl md:block"
            >
              <Image
                src={dachdoktorLeistungen}
                alt="Der Dachdoktor – Robert Storey – Leistungen"
                class="h-full w-full object-cover object-top transition-transform duration-500 group-hover:scale-[1.02]"
                widths={[600, 900]}
                sizes="50vw"
              />
            </a>
          </div>
          <div class="mt-5 flex items-center justify-between">
            <div>
              <h3 class="font-heading text-xl text-white">Der Dachdoktor &ndash; Robert Storey</h3>
              <p class="text-sm text-dark-muted">new.dachdoktor-meisterbetrieb.de</p>
            </div>
            <a
              href="https://new.dachdoktor-meisterbetrieb.de/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sm font-medium text-emerald-400 transition-colors hover:text-emerald-300"
            >
              Website ansehen
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </Container>
</section>
