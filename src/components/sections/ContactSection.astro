---
import Container from "@/components/layout/Container.astro";
import SectionLabel from "@/components/shared/SectionLabel.astro";
import ScrollReveal from "@/components/shared/ScrollReveal.astro";
import { ContactFormIsland } from "@/components/islands/ContactFormIsland";
---
<section id="contact" class="relative overflow-hidden bg-dark py-[clamp(80px,10vw,160px)]">
  <!-- Subtle gradient -->
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 h-[400px] w-[800px] rounded-full bg-emerald-500/5 blur-[120px]"></div>
  </div>

  <Container class="relative">
    <ScrollReveal>
      <div class="mb-12 text-center">
        <SectionLabel text="Kostenlos & unverbindlich" dark />
        <h2 class="mb-3 font-heading text-3xl text-white sm:text-4xl">Jetzt Anfrage senden</h2>
        <p class="text-dark-muted">Ich melde mich innerhalb von 24 Stunden bei Ihnen.</p>
      </div>
    </ScrollReveal>

    <div class="grid items-start gap-8 md:grid-cols-5">
      <!-- Direct contact -->
      <ScrollReveal class="md:col-span-2">
        <div class="rounded-2xl border border-border bg-surface p-6">
          <h3 class="mb-1 font-heading text-xl text-text">Direkter Kontakt</h3>
          <p class="mb-5 text-sm text-text-secondary">Gerne auch per E-Mail oder Telefon.</p>
          <div class="space-y-4">
            <a
              href="mailto:kontakt@digitalhandwerk-mensch.de"
              class="flex items-center gap-3 rounded-xl border border-border bg-surface-muted p-4 transition-colors hover:bg-accent-surface"
            >
              <svg class="h-5 w-5 shrink-0 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <span class="text-sm text-text">kontakt@digitalhandwerk-mensch.de</span>
            </a>
            <a
              href="tel:+4915733962986"
              class="flex items-center gap-3 rounded-xl border border-border bg-surface-muted p-4 transition-colors hover:bg-accent-surface"
            >
              <svg class="h-5 w-5 shrink-0 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              <span class="text-sm text-text">0157 3396 2986</span>
            </a>
          </div>
          <p class="mt-5 text-xs text-text-muted">Ihre Daten sind sicher. DSGVO-konform.</p>
        </div>
      </ScrollReveal>

      <!-- Contact form -->
      <ScrollReveal delay={100} class="md:col-span-3">
        <div class="rounded-2xl border border-border bg-surface p-6 md:p-8">
          <h3 class="mb-1 font-heading text-xl text-text">Kontaktformular</h3>
          <p class="mb-6 text-sm text-text-secondary">Felder mit * sind Pflichtfelder.</p>
          <ContactFormIsland client:visible />
        </div>
      </ScrollReveal>
    </div>
  </Container>
</section>
