---
import Container from "@/components/layout/Container.astro";
import SectionLabel from "@/components/shared/SectionLabel.astro";
import ScrollReveal from "@/components/shared/ScrollReveal.astro";

const included = [
  "Professionelle One-Page Webseite",
  "Mobil-optimiert & responsive auf allen Geräten",
  "Interaktives Kontaktformular",
  "DSGVO-konform, SSL-verschlüsselt, Impressum & Datenschutz",
  "SEO-Optimierung (Meta-Tags, Schema Markup, Sitemap)",
  "Persönliche Beratung & Abstimmung",
];
---
<section id="pakete" class="bg-bg py-[clamp(80px,10vw,160px)]">
  <Container>
    <ScrollReveal>
      <div class="mb-16 max-w-xl">
        <SectionLabel text="Transparent & fair" />
        <h2 class="mb-4 font-heading text-3xl text-text sm:text-4xl">
          Ein Preis. Alles drin.
        </h2>
        <p class="text-lg text-text-secondary leading-relaxed">
          Ein Festpreis, alles inklusive. Sie bekommen eine fertige Website mit allem,
          was Ihr Betrieb braucht, um online Anfragen zu erhalten.
        </p>
      </div>
    </ScrollReveal>

    <div class="grid items-start gap-12 lg:grid-cols-[1.2fr_0.8fr]">
      <!-- Main package -->
      <ScrollReveal>
        <div class="rounded-2xl bg-dark p-8 shadow-xl sm:p-10">
          <div class="mb-8 border-b border-dark-border pb-8">
            <h3 class="mb-1 font-heading text-2xl text-white">Ihre Handwerker-Website</h3>
            <p class="mb-5 text-dark-muted">Komplett. Fertig. Festpreis.</p>
            <div class="flex items-baseline gap-2">
              <span class="font-heading text-6xl text-emerald-400">499 €</span>
              <span class="text-dark-muted">einmalig</span>
            </div>
          </div>

          <div class="space-y-4">
            {included.map((feature) => (
              <div class="flex items-start gap-3">
                <svg class="mt-0.5 h-5 w-5 shrink-0 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-stone-300">{feature}</span>
              </div>
            ))}
          </div>

          <a
            href="#contact"
            class="mt-10 flex w-full items-center justify-center rounded-lg bg-accent px-6 py-4 text-base font-semibold text-white transition-all hover:bg-accent-hover hover:scale-[1.01] active:scale-[0.99]"
          >
            Erstgespräch vereinbaren
          </a>
        </div>
      </ScrollReveal>

      <!-- Side: Hosting + Custom wishes -->
      <div class="space-y-6">
        <ScrollReveal delay={100}>
          <div class="rounded-2xl border border-border bg-surface p-7">
            <h4 class="mb-2 font-heading text-xl text-text">Hosting & Domain</h4>
            <p class="mb-4 text-sm text-text-secondary leading-relaxed">
              Optional. Sie können Ihren eigenen Anbieter nutzen oder ich übernehme das für Sie.
            </p>
            <div class="space-y-2 text-sm">
              <div class="flex items-center justify-between rounded-lg bg-surface-muted px-4 py-3">
                <span class="text-text-secondary">Hosting bei vorhandener Domain</span>
                <span class="font-medium text-text">ab 5 €/Monat</span>
              </div>
              <div class="flex items-center justify-between rounded-lg bg-surface-muted px-4 py-3">
                <span class="text-text-secondary">Domain-Beschaffung & Einrichtung</span>
                <span class="font-medium text-text">auf Anfrage</span>
              </div>
              <div class="flex items-center justify-between rounded-lg bg-surface-muted px-4 py-3">
                <span class="text-text-secondary">Wartung & Updates</span>
                <span class="font-medium text-text">ab 5 €/Monat</span>
              </div>
            </div>
          </div>
        </ScrollReveal>

        <ScrollReveal delay={200}>
          <div class="rounded-2xl border border-border bg-surface p-7">
            <h4 class="mb-2 font-heading text-xl text-text">Individuelle Wünsche?</h4>
            <p class="mb-4 text-sm text-text-secondary leading-relaxed">
              Bildergalerie, Buchungssystem, mehrsprachige Seite, Online-Shop: alles ist machbar. Wir besprechen Ihren Bedarf im Erstgespräch und Sie bekommen ein faires Angebot.
            </p>
            <a
              href="#contact"
              class="inline-flex items-center gap-2 text-sm font-medium text-accent transition-colors hover:text-accent-hover"
            >
              Unverbindlich anfragen
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </ScrollReveal>
      </div>
    </div>
  </Container>
</section>
