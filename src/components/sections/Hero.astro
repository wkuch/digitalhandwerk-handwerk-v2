---
import Container from "@/components/layout/Container.astro";
import ScrollReveal from "@/components/shared/ScrollReveal.astro";
import { Image } from "astro:assets";
import portraitImg from "@/assets/portrait_wanja.jpg";
import heroImg from "@/assets/hero-workshop.webp";
---
<section class="relative overflow-hidden bg-dark">
  <!-- Full-width hero image as background -->
  <div class="absolute inset-0">
    <Image
      src={heroImg}
      alt="Handwerker bei der Arbeit in einer Werkstatt"
      class="h-full w-full object-cover opacity-60"
      widths={[800, 1200, 1600]}
      sizes="100vw"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-dark/90 via-dark/70 to-dark/40"></div>
  </div>

  <!-- Subtle gradient accents -->
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div class="absolute -top-40 right-0 h-[600px] w-[600px] rounded-full bg-emerald-500/8 blur-[120px]"></div>
  </div>

  <Container class="relative">
    <div class="grid min-h-screen items-center pt-24 pb-16 lg:grid-cols-[1.3fr_0.7fr] lg:gap-16">
      <!-- Content -->
      <div class="py-12 lg:py-20">
        <ScrollReveal>
          <span class="mb-6 inline-block text-xs font-semibold uppercase tracking-[0.2em] text-emerald-400">
            Webseiten für Handwerksbetriebe
          </span>
        </ScrollReveal>

        <ScrollReveal delay={100}>
          <h1 class="mb-8 font-heading text-4xl leading-[1.08] text-white sm:text-5xl lg:text-[3.75rem] xl:text-7xl">
            Websites für Handwerksbetriebe.<br />
            Gebaut, als wäre<br class="hidden sm:block" />
            sie meine eigene.
          </h1>
        </ScrollReveal>

        <ScrollReveal delay={200}>
          <p class="mb-12 max-w-xl text-lg leading-relaxed text-stone-300 sm:text-xl">
            Ich bin Wanja, Webentwickler aus Karlsruhe. Deutschlandweit bringe ich
            Handwerksbetriebe online: schnell, rechtssicher, mit Fokus auf echte Anfragen.
          </p>
        </ScrollReveal>

        <ScrollReveal delay={300}>
          <div class="mb-14 flex flex-col items-start gap-4 sm:flex-row">
            <a
              href="#contact"
              class="inline-flex items-center rounded-lg bg-accent px-8 py-4 text-base font-medium text-white transition-all hover:bg-accent-hover hover:scale-[1.02] active:scale-[0.98]"
            >
              Erstgespräch vereinbaren
              <svg class="ml-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
            <a
              href="#pakete"
              class="inline-flex items-center rounded-lg border border-stone-600 px-8 py-4 text-base font-medium text-stone-300 transition-all hover:border-emerald-500/50 hover:text-emerald-400"
            >
Leistungen ansehen
            </a>
          </div>
        </ScrollReveal>

        <!-- Trust signals -->
        <ScrollReveal delay={400}>
          <div class="flex flex-wrap items-center gap-x-8 gap-y-4 text-sm text-stone-400">
            <span class="flex items-center gap-2">
              <span class="h-1.5 w-1.5 rounded-full bg-emerald-400"></span>
              24h Rückmeldung
            </span>
            <span class="flex items-center gap-2">
              <span class="h-1.5 w-1.5 rounded-full bg-emerald-400"></span>
              DSGVO-konform & SSL
            </span>
            <span class="flex items-center gap-2">
              <span class="h-1.5 w-1.5 rounded-full bg-emerald-400"></span>
              Festpreis ab 499 €
            </span>
          </div>
        </ScrollReveal>
      </div>

      <!-- Profile card on right (desktop) -->
      <ScrollReveal delay={300} class="hidden lg:block">
        <div class="rounded-2xl border border-stone-700/40 bg-stone-800/40 p-8 backdrop-blur-md">
          <div class="mb-6 flex items-center gap-5">
            <Image
              src={portraitImg}
              alt="Wanja Mensch"
              class="h-20 w-20 rounded-full object-cover ring-2 ring-emerald-500/20"
              width={80}
              height={80}
            />
            <div>
              <p class="font-heading text-2xl text-white">Wanja Mensch</p>
              <p class="text-sm text-stone-400">Webentwickler & Digitalberater</p>
            </div>
          </div>
          <blockquote class="border-l-2 border-emerald-500/40 pl-5 text-stone-300 italic leading-relaxed">
            &bdquo;Ich baue Ihre Webseite so, als wäre es meine eigene:
            strukturiert, schnell und mit Blick aufs Wesentliche &ndash;
            Ihre Kundengewinnung.&ldquo;
          </blockquote>
          <div class="mt-6 flex items-center gap-2">
            <span class="inline-flex items-center rounded-full bg-emerald-600/20 px-3 py-1 text-xs font-medium text-emerald-400">
              Direkt
            </span>
            <span class="text-sm text-stone-500">Persönlicher Kontakt, keine Agentur</span>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </Container>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="h-6 w-6 text-emerald-400/60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>
