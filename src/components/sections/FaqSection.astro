---
import Container from "@/components/layout/Container.astro";
import SectionLabel from "@/components/shared/SectionLabel.astro";
import ScrollReveal from "@/components/shared/ScrollReveal.astro";
import { FaqIsland } from "@/components/islands/FaqIsland";
---
<section id="faq" class="bg-surface-muted py-[clamp(80px,10vw,160px)]">
  <Container>
    <div class="grid gap-12 md:grid-cols-[0.8fr_1.2fr] lg:gap-20">
      <!-- Left: Label + CTA -->
      <ScrollReveal>
        <div class="md:sticky md:top-32">
          <SectionLabel text="Fragen & Antworten" />
          <h2 class="mb-4 font-heading text-3xl text-text sm:text-4xl">
            Rund um Ihre neue Webseite
          </h2>
          <p class="mb-6 text-text-secondary leading-relaxed">
            Die häufigsten Fragen zu Ablauf, Kosten und Technik.
            Frage nicht dabei?
          </p>
          <a
            href="#contact"
            class="inline-flex items-center gap-2 text-sm font-medium text-accent transition-colors hover:text-accent-hover"
          >
            Schreiben Sie mir direkt
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </ScrollReveal>

      <!-- Right: Accordion -->
      <ScrollReveal delay={100}>
        <div class="rounded-2xl border border-border bg-surface p-6 md:p-8">
          <FaqIsland client:visible />
        </div>
      </ScrollReveal>
    </div>
  </Container>
</section>
