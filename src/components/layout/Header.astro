---
import { Image } from "astro:assets";
import logoImg from "@/assets/Logo.png";
---
<header
  id="site-header"
  class="fixed inset-x-0 top-0 z-50 border-b border-transparent bg-dark/95 backdrop-blur-sm transition-all duration-300"
>
  <div
    id="header-inner"
    class="mx-auto flex h-20 max-w-[1200px] items-center justify-between px-6 transition-all duration-300 md:px-8"
  >
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3">
      <Image
        src={logoImg}
        alt="DigitalHandwerk Logo"
        id="site-logo"
        class="h-14 w-14 rounded-md transition-all duration-300"
        width={56}
        height={56}
      />
      <div class="leading-tight">
        <span id="brand-name" class="block text-sm font-semibold tracking-tight text-white transition-colors duration-300">
          DigitalHandwerk
        </span>
        <span id="brand-sub" class="block text-xs text-dark-muted transition-colors duration-300">
          von Wanja Mensch
        </span>
      </div>
    </a>

    <!-- Desktop Nav -->
    <nav id="site-nav" aria-label="Hauptnavigation" class="hidden items-center gap-8 md:flex">
      <a href="#pakete" class="nav-link text-sm text-stone-300 transition-colors hover:text-white">Leistungen</a>
      <a href="#ablauf" class="nav-link text-sm text-stone-300 transition-colors hover:text-white">Ablauf</a>
      <a href="#referenzen" class="nav-link text-sm text-stone-300 transition-colors hover:text-white">Referenzen</a>
      <a href="#ueber-mich" class="nav-link text-sm text-stone-300 transition-colors hover:text-white">Über mich</a>
      <a href="#faq" class="nav-link text-sm text-stone-300 transition-colors hover:text-white">FAQ</a>
      <a
        href="#contact"
        class="inline-flex items-center rounded-md bg-accent px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-accent-hover"
      >
        Erstgespräch vereinbaren
      </a>
    </nav>

    <!-- Mobile Menu Button -->
    <button
      id="menu-toggle"
      type="button"
      class="relative z-60 flex h-10 w-10 items-center justify-center rounded-md md:hidden"
      aria-label="Menü öffnen"
      aria-expanded="false"
    >
      <div id="menu-icon" class="flex flex-col gap-1.5">
        <span class="block h-0.5 w-6 bg-white transition-all duration-300 origin-center"></span>
        <span class="block h-0.5 w-6 bg-white transition-all duration-300"></span>
        <span class="block h-0.5 w-6 bg-white transition-all duration-300 origin-center"></span>
      </div>
    </button>
  </div>
</header>

<!-- Mobile Menu Overlay -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-50 flex translate-x-full flex-col bg-dark transition-transform duration-300 md:hidden"
>
  <div class="flex h-20 items-center justify-end px-6">
    <button
      id="menu-close"
      type="button"
      class="flex h-10 w-10 items-center justify-center rounded-md text-white"
      aria-label="Menü schließen"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>
  <nav aria-label="Hauptnavigation" class="flex flex-1 flex-col items-center justify-center gap-8">
    <a href="#pakete" class="mobile-nav-link font-heading text-3xl text-white">Leistungen</a>
    <a href="#ablauf" class="mobile-nav-link font-heading text-3xl text-white">Ablauf</a>
    <a href="#referenzen" class="mobile-nav-link font-heading text-3xl text-white">Referenzen</a>
    <a href="#ueber-mich" class="mobile-nav-link font-heading text-3xl text-white">Über mich</a>
    <a href="#faq" class="mobile-nav-link font-heading text-3xl text-white">FAQ</a>
    <a
      href="#contact"
      class="mobile-nav-link mt-4 inline-flex items-center rounded-md bg-accent px-8 py-3 text-lg font-medium text-white"
    >
      Erstgespräch vereinbaren
    </a>
  </nav>
</div>

<script>
  const header = document.getElementById("site-header")!;
  const inner = document.getElementById("header-inner")!;
  const logo = document.getElementById("site-logo")!;
  const brandName = document.getElementById("brand-name")!;
  const brandSub = document.getElementById("brand-sub")!;
  const navLinks = document.querySelectorAll<HTMLAnchorElement>("#site-nav .nav-link");
  const menuToggle = document.getElementById("menu-toggle")!;
  const menuClose = document.getElementById("menu-close")!;
  const mobileMenu = document.getElementById("mobile-menu")!;
  const mobileLinks = document.querySelectorAll<HTMLAnchorElement>(".mobile-nav-link");

  function onScroll() {
    const scrolled = window.scrollY > 40;
    header.classList.toggle("bg-dark/95", !scrolled);
    header.classList.toggle("bg-white/95", scrolled);
    header.classList.toggle("border-transparent", !scrolled);
    header.classList.toggle("border-border", scrolled);
    header.classList.toggle("shadow-sm", scrolled);
    inner.classList.toggle("h-20", !scrolled);
    inner.classList.toggle("h-16", scrolled);
    logo.classList.toggle("h-14", !scrolled);
    logo.classList.toggle("w-14", !scrolled);
    logo.classList.toggle("h-10", scrolled);
    logo.classList.toggle("w-10", scrolled);
    brandName.classList.toggle("text-white", !scrolled);
    brandName.classList.toggle("text-text", scrolled);
    brandSub.classList.toggle("text-dark-muted", !scrolled);
    brandSub.classList.toggle("text-text-muted", scrolled);
    navLinks.forEach((a) => {
      a.classList.toggle("text-stone-300", !scrolled);
      a.classList.toggle("hover:text-white", !scrolled);
      a.classList.toggle("text-text-secondary", scrolled);
      a.classList.toggle("hover:text-text", scrolled);
    });
    // Menu icon color
    const bars = document.querySelectorAll<HTMLSpanElement>("#menu-icon span");
    bars.forEach((bar) => {
      bar.classList.toggle("bg-white", !scrolled);
      bar.classList.toggle("bg-text", scrolled);
    });
  }

  function openMenu() {
    mobileMenu.classList.remove("translate-x-full");
    mobileMenu.classList.add("translate-x-0");
    document.body.style.overflow = "hidden";
    menuToggle.setAttribute("aria-expanded", "true");
  }

  function closeMenu() {
    mobileMenu.classList.remove("translate-x-0");
    mobileMenu.classList.add("translate-x-full");
    document.body.style.overflow = "";
    menuToggle.setAttribute("aria-expanded", "false");
  }

  menuToggle.addEventListener("click", openMenu);
  menuClose.addEventListener("click", closeMenu);
  mobileLinks.forEach((link) => link.addEventListener("click", closeMenu));

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeMenu();
  });

  window.addEventListener("scroll", onScroll, { passive: true });
  onScroll();
</script>
