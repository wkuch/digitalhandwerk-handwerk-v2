---
import { Image } from "astro:assets";
import logoImg from "@/assets/Logo.png";
---
<footer class="border-t border-dark-border bg-dark px-6 py-16 md:px-8">
  <div class="mx-auto max-w-[1200px]">
    <div class="grid gap-10 md:grid-cols-3">
      <!-- Brand -->
      <div>
        <a href="/" class="mb-4 inline-flex items-center gap-3">
          <Image
            src={logoImg}
            alt="DigitalHandwerk Logo"
            class="h-12 w-12 rounded-md"
            width={48}
            height={48}
          />
          <div class="leading-tight">
            <span class="block text-sm font-semibold text-white">DigitalHandwerk</span>
            <span class="block text-xs text-dark-muted">von Wanja Mensch</span>
          </div>
        </a>
        <p class="mt-3 max-w-xs text-sm leading-relaxed text-dark-muted">
          Professionelle Webseiten für Handwerksbetriebe. Persönlich, schnell, rechtssicher.
        </p>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="mb-4 text-sm font-semibold text-white">Kontakt</h4>
        <div class="space-y-3 text-sm text-dark-muted">
          <a
            href="mailto:kontakt@digitalhandwerk.net"
            class="flex items-center gap-2 transition-colors hover:text-accent-light"
          >
            <svg class="h-4 w-4 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            kontakt@digitalhandwerk.net
          </a>
          <a
            href="tel:+4915733962986"
            class="flex items-center gap-2 transition-colors hover:text-accent-light"
          >
            <svg class="h-4 w-4 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            0157 3396 2986
          </a>
        </div>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="mb-4 text-sm font-semibold text-white">Rechtliches</h4>
        <div class="space-y-3 text-sm">
          <a href="/impressum" class="block text-dark-muted transition-colors hover:text-accent-light">Impressum</a>
          <a href="/datenschutz" class="block text-dark-muted transition-colors hover:text-accent-light">Datenschutz</a>
        </div>
      </div>
    </div>

    <div class="mt-12 border-t border-dark-border pt-6 text-center">
      <p class="text-sm text-dark-muted">&copy; 2026 DigitalHandwerk &ndash; Wanja Mensch. Alle Rechte vorbehalten.</p>
    </div>
  </div>
</footer>
