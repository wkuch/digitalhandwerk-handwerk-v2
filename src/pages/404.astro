---
import BaseLayout from "@/components/layout/BaseLayout.astro";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import Container from "@/components/layout/Container.astro";
---
<BaseLayout title="Seite nicht gefunden – DigitalHandwerk">
  <meta slot="head" name="robots" content="noindex" />
  <Header />
  <main id="main" class="flex min-h-screen items-center bg-bg pt-20">
    <Container class="py-20 text-center">
      <p class="mb-4 text-7xl font-heading text-text-muted">404</p>
      <h1 class="mb-4 font-heading text-3xl text-text">Diese Seite gibt es nicht.</h1>
      <p class="mb-8 text-lg text-text-secondary">Aber Ihre neue Handwerker-Website schon bald.</p>
      <a
        href="/"
        class="inline-flex items-center rounded-lg bg-accent px-6 py-3 text-base font-medium text-white transition-all hover:bg-accent-hover"
      >
        Zurück zur Startseite
      </a>
    </Container>
  </main>
  <Footer />
</BaseLayout>
