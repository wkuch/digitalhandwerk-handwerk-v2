---
import BaseLayout from "@/components/layout/BaseLayout.astro";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import Container from "@/components/layout/Container.astro";
import ScrollReveal from "@/components/shared/ScrollReveal.astro";
import PackagesSection from "@/components/sections/PackagesSection.astro";
import ProcessSection from "@/components/sections/ProcessSection.astro";
import ContactSection from "@/components/sections/ContactSection.astro";
import FaqSection from "@/components/sections/FaqSection.astro";
import { Image } from "astro:assets";
import heroImg from "@/assets/hero-karlsruhe.jpg";

const title = "Webdesign für Handwerker Karlsruhe – 499 € Festpreis | DigitalHandwerk";
const description = "Professionelle Websites für Handwerksbetriebe in Karlsruhe und Umgebung. Ab 499 € Festpreis, DSGVO-konform, persönliche Beratung. Jetzt Angebot anfragen.";
const canonical = "https://www.digitalhandwerk.net/webdesign-karlsruhe-handwerker/";

const trades = [
  { label: "Elektriker", href: "/website-fuer-elektriker/" },
  { label: "Sanitär", href: "/website-fuer-sanitaer/" },
  { label: "Schreiner", href: "/website-fuer-schreiner/" },
  { label: "Maler", href: "/website-fuer-maler/" },
  { label: "KFZ-Betrieb", href: "/website-fuer-kfz-betrieb/" },
  { label: "Dachdecker", href: "/website-fuer-dachdecker/" },
];
---
<BaseLayout title={title} description={description} canonical={canonical}>
  <Header />
  <main id="main">

    <!-- Hero -->
    <section class="relative overflow-hidden bg-dark">
      <div class="absolute inset-0">
        <Image
          src={heroImg}
          alt="Karlsruhe Skylight – Schloss und Stadtzentrum"
          class="h-full w-full object-cover opacity-50"
          widths={[800, 1200, 1600]}
          sizes="100vw"
          loading="eager"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-dark/90 via-dark/70 to-dark/30"></div>
      </div>
      <div class="pointer-events-none absolute inset-0" aria-hidden="true">
        <div class="absolute -top-40 right-0 h-[600px] w-[600px] rounded-full bg-emerald-500/8 blur-[120px]"></div>
      </div>
      <Container class="relative">
        <div class="flex min-h-screen items-center py-32">
          <div class="max-w-2xl">
            <ScrollReveal>
              <span class="mb-6 inline-block text-xs font-semibold uppercase tracking-[0.2em] text-emerald-400">
                Webdesign aus Karlsruhe
              </span>
            </ScrollReveal>
            <ScrollReveal delay={100}>
              <h1 class="mb-8 font-heading text-4xl leading-[1.08] text-white sm:text-5xl lg:text-[3.5rem]">
                Webdesign für Handwerker<br />
                in Karlsruhe – direkt aus<br class="hidden sm:block" />
                Ihrer Region, ab 499 €.
              </h1>
            </ScrollReveal>
            <ScrollReveal delay={200}>
              <p class="mb-12 max-w-xl text-lg leading-relaxed text-stone-300">
                Sie führen einen Handwerksbetrieb in Karlsruhe, Ettlingen, Bruchsal oder Pforzheim?
                Ich baue Ihnen eine professionelle Website, die neue Kunden bringt – persönlich, schnell
                und DSGVO-konform. Ein Festpreis, alles drin.
              </p>
            </ScrollReveal>
            <ScrollReveal delay={300}>
              <div class="mb-14 flex flex-col items-start gap-4 sm:flex-row">
                <a
                  href="#contact"
                  class="inline-flex items-center rounded-lg bg-accent px-8 py-4 text-base font-medium text-white transition-all hover:bg-accent-hover hover:scale-[1.02] active:scale-[0.98]"
                >
                  Erstgespräch vereinbaren
                  <svg class="ml-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </a>
                <a
                  href="#pakete"
                  class="inline-flex items-center rounded-lg border border-stone-600 px-8 py-4 text-base font-medium text-stone-300 transition-all hover:border-emerald-500/50 hover:text-emerald-400"
                >
                  Leistungen ansehen
                </a>
              </div>
            </ScrollReveal>
            <ScrollReveal delay={400}>
              <div class="flex flex-wrap items-center gap-x-8 gap-y-4 text-sm text-stone-400">
                <span class="flex items-center gap-2">
                  <span class="h-1.5 w-1.5 rounded-full bg-emerald-400"></span>
                  Persönliche Betreuung
                </span>
                <span class="flex items-center gap-2">
                  <span class="h-1.5 w-1.5 rounded-full bg-emerald-400"></span>
                  DSGVO-konform & SSL
                </span>
                <span class="flex items-center gap-2">
                  <span class="h-1.5 w-1.5 rounded-full bg-emerald-400"></span>
                  Festpreis 499 €
                </span>
              </div>
            </ScrollReveal>
          </div>
        </div>
      </Container>
    </section>

    <!-- Local benefits -->
    <section class="bg-surface py-[clamp(64px,8vw,120px)]">
      <Container>
        <ScrollReveal>
          <span class="mb-4 inline-block text-xs font-semibold uppercase tracking-[0.2em] text-emerald-600">Lokaler Vorteil</span>
          <h2 class="mb-16 max-w-lg font-heading text-3xl text-text sm:text-4xl">
            Ihr Webdesigner aus Karlsruhe – vor Ort, wenn Sie ihn brauchen.
          </h2>
        </ScrollReveal>
        <div class="space-y-12 md:space-y-16">
          <ScrollReveal>
            <div class="grid items-start gap-8 md:grid-cols-[1fr_1.4fr]">
              <h3 class="font-heading text-2xl text-text sm:text-3xl">In Karlsruhe zuhause</h3>
              <p class="text-lg leading-relaxed text-text-secondary">
                Ich kenne die Region und ihre Betriebe. Ob aus der Karlsruher Südstadt, Durlach,
                Mühlburg oder den Vororten – ein persönliches Treffen vor Ort ist jederzeit möglich.
                Kein Callcenter, kein anonymer Anbieter aus dem Ausland. Ihr direkter Ansprechpartner.
              </p>
            </div>
          </ScrollReveal>
          <ScrollReveal>
            <div class="grid items-start gap-8 md:grid-cols-[1.4fr_1fr]">
              <p class="order-2 text-lg leading-relaxed text-text-secondary md:order-1">
                In Ettlingen, Bruchsal, Pforzheim oder Bretten gibt es Hunderte Handwerksbetriebe
                ohne moderne Website. Ich helfe Ihnen, sich lokal sichtbar zu machen – mit einer
                Seite, die genau auf Ihre Region und Ihr Gewerk zugeschnitten ist.
              </p>
              <h3 class="order-1 font-heading text-2xl text-text sm:text-3xl md:order-2 md:text-right">
                Von Karlsruhe ins Umland
              </h3>
            </div>
          </ScrollReveal>
          <ScrollReveal>
            <div class="grid items-start gap-8 md:grid-cols-[1fr_1.4fr]">
              <h3 class="font-heading text-2xl text-text sm:text-3xl">Wettbewerber im Blick</h3>
              <p class="text-lg leading-relaxed text-text-secondary">
                Agenturen in Karlsruhe nehmen oft Tagesätze von über 1.000 €. Als Solo-Entwickler
                biete ich die gleiche Qualität zum Festpreis von 499 € – weil ich ohne Agentur-Ballast
                arbeite und die Ersparnis direkt an Sie weitergebe.
              </p>
            </div>
          </ScrollReveal>
          <ScrollReveal>
            <div class="grid items-start gap-8 md:grid-cols-[1.4fr_1fr]">
              <p class="order-2 text-lg leading-relaxed text-text-secondary md:order-1">
                Ihre Kunden suchen online nach Handwerkern in Karlsruhe und der Region. Mit lokalem
                SEO (Google Maps, Branchenbucheinträge, regionale Keywords) mache ich Sie genau dort
                sichtbar, wo neue Aufträge entstehen.
              </p>
              <h3 class="order-1 font-heading text-2xl text-text sm:text-3xl md:order-2 md:text-right">
                Sichtbar in Ihrer Stadt
              </h3>
            </div>
          </ScrollReveal>
        </div>
      </Container>
    </section>

    <PackagesSection />
    <ProcessSection />
    <FaqSection />

    <!-- Cross-links to trade pages -->
    <section class="bg-surface-muted py-[clamp(64px,8vw,100px)]">
      <Container>
        <h2 class="mb-12 text-center font-heading text-3xl text-text sm:text-4xl">
          Auch für diese Gewerke
        </h2>
        <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-6">
          {trades.map((trade) => (
            <a
              href={trade.href}
              class="flex items-center justify-center rounded-xl border border-border bg-surface p-4 text-sm font-medium text-text-secondary transition-all hover:border-accent/30 hover:text-accent hover:shadow-sm"
            >
              {trade.label}
            </a>
          ))}
        </div>
      </Container>
    </section>

    <ContactSection />
  </main>
  <Footer />

  <!-- Structured Data: Service -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "Webdesign für Handwerksbetriebe in Karlsruhe",
    "provider": {
      "@type": "ProfessionalService",
      "name": "DigitalHandwerk – Wanja Mensch",
      "url": "https://www.digitalhandwerk.net"
    },
    "areaServed": {
      "@type": "City",
      "name": "Karlsruhe",
      "containedInPlace": {
        "@type": "AdministrativeArea",
        "name": "Baden-Württemberg"
      }
    },
    "description": "Professionelle Websites für Handwerksbetriebe in Karlsruhe und Umgebung – 499 € Festpreis, alles inklusive: Design, SEO, DSGVO, Kontaktformular. Persönliche Beratung vor Ort.",
    "offers": {
      "@type": "Offer",
      "price": "499",
      "priceCurrency": "EUR",
      "description": "499 € Festpreis – Website für Handwerksbetriebe, alles inklusive."
    }
  })} />

  <!-- FAQ Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "name": "Häufige Fragen zu Handwerker-Websites in Karlsruhe",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Was kostet eine Website für Handwerker in Karlsruhe?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Eine professionelle Website für Ihren Handwerksbetrieb in Karlsruhe kostet bei DigitalHandwerk 499 € als einmaliger Festpreis. Darin enthalten: Design, SEO-Grundlagen, DSGVO-konforme Umsetzung mit Impressum und Datenschutzerklärung, mobil-optimiertes Layout und Kontaktformular. Kein Abo, keine versteckten Kosten."
        }
      },
      {
        "@type": "Question",
        "name": "Kann ich mich persönlich in Karlsruhe beraten lassen?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ja. Ich bin in Karlsruhe ansässig und stehe für persönliche Treffen vor Ort zur Verfügung – sei es in der Südstadt, Durlach oder wo immer Sie Ihren Betrieb haben. Auch im Umland (Ettlingen, Bruchsal, Pforzheim) sind Termine möglich."
        }
      },
      {
        "@type": "Question",
        "name": "Wie lange dauert es, bis meine Webseite online ist?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "In der Regel ist die Website innerhalb von 2–4 Wochen fertig und live. Nach einem kurzen Erstgespräch erhalten Sie einen konkreten Zeitplan. Sie entscheiden, wie viel Sie selbst beitragen möchten."
        }
      }
    ]
  })} />
</BaseLayout>
