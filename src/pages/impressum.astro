---
import BaseLayout from "@/components/layout/BaseLayout.astro";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import Container from "@/components/layout/Container.astro";
---
<BaseLayout
  title="Impressum – DigitalHandwerk"
  description="Impressum von DigitalHandwerk – Wanja Mensch, Im Haberacker 3A, 76227 Karlsruhe."
  canonical="https://www.digitalhandwerk.net/impressum"
>
  <Header />
  <main id="main" class="min-h-screen bg-bg pt-28 pb-20">
    <Container class="max-w-3xl">
      <a
        href="/"
        class="mb-8 inline-flex items-center gap-2 text-sm font-medium text-accent transition-colors hover:text-accent-hover"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 12H5M12 5l-7 7 7 7" />
        </svg>
        Zurück zur Startseite
      </a>

      <article class="rounded-2xl border border-border bg-surface p-8 md:p-12 shadow-sm">
        <h1 class="mb-10 font-heading text-3xl text-text sm:text-4xl">Impressum</h1>

        <div class="space-y-8 text-text-secondary leading-relaxed">
          <section>
            <h2 class="mb-3 font-heading text-xl text-text">Angaben gemäß § 5 TMG</h2>
            <p>
              Wanja Mensch<br />
              DigitalHandwerk<br />
              Im Haberacker 3A<br />
              76227 Karlsruhe
            </p>
          </section>

          <section>
            <h2 class="mb-3 font-heading text-xl text-text">Kontakt</h2>
            <p>
              E-Mail: kontakt@digitalhandwerk.net<br />
              Telefon: 015733962986
            </p>
          </section>
        </div>
      </article>
    </Container>
  </main>
  <Footer />

  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Startseite", "item": "https://www.digitalhandwerk.net/" },
      { "@type": "ListItem", "position": 2, "name": "Impressum", "item": "https://www.digitalhandwerk.net/impressum" }
    ]
  })} />
</BaseLayout>
